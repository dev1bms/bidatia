# Copy to `.env` and adjust for your environment, then export these variables
# (or load them via your process manager / hosting platform) before running Django.
# Local development works with zero configuration — these are for staging/production.
# NEVER commit a real .env with secrets. Only this example file is tracked.

# ── Core Django ───────────────────────────────────────────────────────────────
# Generate a fresh key, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-long-random-value

# Must be False in production.
DJANGO_DEBUG=False

# Comma-separated hostnames this site is served on.
DJANGO_ALLOWED_HOSTS=bidatia.xyz,www.bidatia.xyz

# Comma-separated origins (with scheme) for CSRF-protected POSTs over HTTPS.
DJANGO_CSRF_TRUSTED_ORIGINS=https://bidatia.xyz,https://www.bidatia.xyz

# Absolute base URL. Also the canonical origin for SEO: in production all
# canonical/hreflang/Open-Graph URLs are pinned to this domain so www/non-www
# and proxy hosts consolidate onto one origin.
SITE_BASE_URL=https://bidatia.xyz

# Optional override for the social-share image (og:image / twitter:image).
# Leave unset to use the bundled 1200×630 card at /static/img/og.png. Set this
# only to point at a different absolute image URL (e.g. a CDN asset).
# OG_DEFAULT_IMAGE=https://bidatia.xyz/static/img/custom-og.png

# ── Public contact details (shown on the website) ─────────────────────────────
CONTACT_EMAIL=info@bidatia.xyz
CONTACT_WHATSAPP=+34 911 23 45 67

# ── Email / SMTP (outgoing only) ──────────────────────────────────────────────
# Leave DJANGO_EMAIL_BACKEND unset to auto-select: console in DEBUG, SMTP in prod.
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.your-mail-host.example
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=info@bidatia.xyz
# Set the real mailbox password ONLY in the environment — never commit it.
EMAIL_HOST_PASSWORD=change-me
DEFAULT_FROM_EMAIL=Bidatia Business Systems <info@bidatia.xyz>
SERVER_EMAIL=info@bidatia.xyz

# Where contact/booking notifications are delivered.
CONTACT_NOTIFICATION_EMAIL=info@bidatia.xyz
# Comma-separated Cc recipients (optional).
CONTACT_NOTIFICATION_CC=

# ── Analytics / Search Console (production only, optional) ────────────────────
# Both are empty by default so no third-party tracking id ships with the repo.
# Set the GA4 measurement id to enable Google Analytics (loads only when
# DJANGO_DEBUG=False). Set the verification token to prove domain ownership.
# GA_MEASUREMENT_ID=G-XXXXXXXXXX
# GOOGLE_SITE_VERIFICATION=your-search-console-token

# ── Celery / Redis (background tasks for the free tools) ─────────────────────
# Broker connection for the Celery worker and beat scheduler.
# Local default (no auth): redis://localhost:6379/0
# With a password:         redis://:yourpassword@localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Local development ONLY: run Celery tasks synchronously without Redis/worker.
# Never set this in production.
# CELERY_TASK_ALWAYS_EAGER=True

# Optional external booking link (e.g. Calendly) used by tool-report CTAs.
# Leave unset to use the internal /book-consultation/ flow.
# TOOLS_BOOKING_URL=https://calendly.com/bidatia/30min

# ── Local AI insights (Ollama on the same server) ─────────────────────────────
# The model only INTERPRETS finished scan results (never decides scores, never
# sees credentials, data never leaves the server). Unset to disable.
OLLAMA_URL=http://127.0.0.1:11434
TOOLS_AI_MODEL=gemma4:26b
# Overall AI budget. Thinking models REASON before answering — keep generous.
TOOLS_AI_TIMEOUT=240
# Live-thinking showtime in seconds before cutting to the fast strict answer.
# 0 = fastest scans (no real-thinking display), 60 = a minute of live reasoning.
TOOLS_AI_THINKING_BUDGET=60
