#: templates/tool_studio_xray/landing.html:79
msgid "Log in as that user (or use your own user if you prefer)."
msgstr "Inicia sesión con ese usuario (o usa el tuyo si lo prefieres)."

#: templates/tool_studio_xray/landing.html:80
