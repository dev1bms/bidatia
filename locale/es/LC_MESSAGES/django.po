#: tool_data_risk/views.py:37 tools_core/badge_views.py:25
msgid "Low data migration risk"
msgstr "Riesgo de migración de datos bajo"

#: tool_data_risk/views.py:38
msgid "Moderate risk"
msgstr "Riesgo moderado"

#: tool_data_risk/views.py:39
msgid "High risk"
msgstr "Riesgo alto"

#: tool_data_risk/views.py:40
msgid "Critical cleanup needed"
msgstr "Se necesita una limpieza crítica"

#: tool_data_risk/views.py:44
msgid ""
"Your master data looks largely migration-ready. Review the flagged items "
"below and keep the habits that got you here."
msgstr ""
"Tus datos maestros parecen en gran medida listos para migrar. Revisa los "
"puntos marcados y mantén los hábitos que te trajeron hasta aquí."

#: tool_data_risk/views.py:45
msgid ""
"Workable, but several areas will create friction during import and mapping. "
"Cleaning them before the migration starts is much cheaper than during it."
msgstr ""
"Manejable, pero varias áreas crearán fricción durante la importación y el "
"mapeo. Limpiarlas antes de empezar la migración es mucho más barato que "
"durante ella."

#: tool_data_risk/views.py:46
msgid ""
"Multiple data areas carry real migration risk. Plan a cleanup sprint before "
"committing to a migration timeline."
msgstr ""
"Varias áreas de datos conllevan riesgo real de migración. Planifica un "
"sprint de limpieza antes de comprometerte con un calendario."

#: tool_data_risk/views.py:47
msgid ""
"This profile matches projects where data issues dominate the migration "
"budget. A structured cleanup phase should come before any migration work."
msgstr ""
"Este perfil coincide con proyectos donde los problemas de datos dominan el "
"presupuesto de migración. Una fase de limpieza estructurada debe preceder a "
"cualquier trabajo de migración."

#: tool_data_risk/views.py:51
msgid "Duplicate risk"
msgstr "Riesgo de duplicados"

#: tool_data_risk/views.py:52
msgid "Missing master data"
msgstr "Datos maestros incompletos"

#: tool_data_risk/views.py:53
msgid "Relationship & orphan risk"
msgstr "Riesgo de relaciones y huérfanos"

#: tool_data_risk/views.py:54
msgid "Import identifier coverage"
msgstr "Cobertura de identificadores de importación"

#: tool_data_risk/views.py:55
msgid "Configuration & reference data"
msgstr "Configuración y datos de referencia"

#: tool_data_risk/views.py:56
msgid "Attachments & database bloat"
msgstr "Adjuntos e inflado de la base de datos"

#: tool_data_risk/views.py:57
msgid "Inactive-user ownership"
msgstr "Propiedad de usuarios inactivos"

#: tool_data_risk/views.py:58
msgid "Custom / Studio data"
msgstr "Datos personalizados / Studio"

#: tool_data_risk/views.py:62
msgid ""
"Potential duplicate clusters in partners and products. Ambiguous names also "
"break many2one matching during import."
msgstr ""
"Posibles grupos de duplicados en contactos y productos. Los nombres ambiguos"
" también rompen el mapeo many2one al importar."

#: tool_data_risk/views.py:63
msgid ""
"Records missing the fields imports and daily operations rely on: contact "
"details, VAT numbers, countries, internal references."
msgstr ""
"Registros sin los campos de los que dependen las importaciones y la "
"operación diaria: datos de contacto, NIF, países, referencias internas."

#: tool_data_risk/views.py:64
msgid ""
"Live documents pointing at archived partners, archived products or abandoned"
" pipelines — mapping hazards during migration."
msgstr ""
"Documentos vivos que apuntan a contactos archivados, productos archivados o "
"pipelines abandonados — peligros de mapeo durante la migración."

#: tool_data_risk/views.py:65
msgid ""
"External-ID coverage of master data. Missing IDs are normal for UI-created "
"records, but they make repeat imports and update-imports duplicate-prone."
msgstr ""
"Cobertura de External IDs en datos maestros. Su ausencia es normal en "
"registros creados por la interfaz, pero hace que las reimportaciones tiendan"
" a duplicar."

#: tool_data_risk/views.py:66
msgid ""
"Reference-data signals worth a look before migrating: currencies, "
"categories, long-lived draft entries."
msgstr ""
"Señales de datos de referencia que conviene mirar antes de migrar: monedas, "
"categorías, borradores antiguos."

#: tool_data_risk/views.py:67
msgid ""
"Attachment volume drives database size — and database size drives upgrade, "
"rehearsal and restore times."
msgstr ""
"El volumen de adjuntos determina el tamaño de la base — y el tamaño "
"determina los tiempos de actualización, ensayo y restauración."

#: tool_data_risk/views.py:68
msgid ""
"Active records owned by deactivated users lose their workflows quietly and "
"confuse assignment after migration."
msgstr ""
"Los registros activos de usuarios desactivados pierden sus flujos en "
"silencio y confunden la asignación tras la migración."

#: tool_data_risk/views.py:69
msgid ""
"Custom (Studio) models holding significant data without stable identifiers —"
" they will not map themselves."
msgstr ""
"Modelos personalizados (Studio) con datos significativos sin identificadores"
" estables — no se mapearán solos."

#: tool_data_risk/views.py:73
msgid "Duplicates"
msgstr "Duplicados"

#: tool_data_risk/views.py:74
msgid "Missing data"
msgstr "Datos faltantes"

#: tool_data_risk/views.py:75
