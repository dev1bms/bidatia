msgstr ""
"أعد تطبيق تعديلات واجهات Studio اللازمة كوراثة XML نظيفة داخل وحدة برمجية."

#: tool_studio_xray/views.py:904
#, python-format
msgid ""
"Plan the upgrade path towards Odoo %(v)s and budget the cleanup before "
"migrating."
msgstr "خطّط لمسار الترقية نحو Odoo %(v)s وخصّص ميزانية للتنظيف قبل الترحيل."

#: tool_studio_xray/views.py:907
