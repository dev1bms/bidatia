#: templates/partials/admin_toolbar.html:28
msgid "Admin tools"
msgstr "أدوات الإدارة"

#: templates/partials/admin_toolbar.html:16
msgid "BidERP admin"
msgstr "لوحة إدارة BidERP"

#: templates/partials/admin_toolbar.html:19
msgid "Admin dashboard"
msgstr "لوحة تحكم الإدارة"

